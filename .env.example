# ============================================================
# Adynex – Konfiguration (.env.example → .env kopieren)
# ============================================================

# Flask
FLASK_SECRET_KEY=hier-einen-langen-zufaelligen-string-eintragen
FLASK_ENV=development

# Datenbank
# Entwicklung: SQLite (Standard, kein Setup nötig)
# Produktion:  postgresql://user:password@localhost/adynex
DATABASE_URL=sqlite:///adynex.db

# E-Mail (für Benachrichtigungen)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ihre@email.de
MAIL_PASSWORD=ihr-app-passwort
MAIL_FROM=noreply@adynex.de

# ── Google Ads (pro Mandant in der DB gespeichert, hier nur Fallback) ──
GOOGLE_ADS_DEVELOPER_TOKEN=DEIN_DEVELOPER_TOKEN
GOOGLE_ADS_CLIENT_ID=DEINE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=DEIN_CLIENT_SECRET
GOOGLE_ADS_REFRESH_TOKEN=DEIN_REFRESH_TOKEN
GOOGLE_ADS_MCC_ID=1234567890
GOOGLE_ADS_CUSTOMER_ID=0987654321

# ── Microsoft Ads (pro Mandant in der DB gespeichert, hier nur Fallback) ──
MICROSOFT_ADS_DEVELOPER_TOKEN=DEIN_DEVELOPER_TOKEN
MICROSOFT_ADS_CLIENT_ID=DEINE_APP_CLIENT_ID
MICROSOFT_ADS_CLIENT_SECRET=DEIN_CLIENT_SECRET
MICROSOFT_ADS_REFRESH_TOKEN=DEIN_REFRESH_TOKEN
MICROSOFT_ADS_CUSTOMER_ID=DEINE_CUSTOMER_ID
MICROSOFT_ADS_ACCOUNT_ID=DEINE_ACCOUNT_ID
